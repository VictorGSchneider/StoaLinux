{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 0,

    "modules-left": ["hyprland/workspaces"],
    "modules-center": [],
    "modules-right": [
        "disk",
        "network",
        "battery",
        "cpu",
        "memory",
        "wireplumber",
        "clock"
    ],

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "I",
            "2": "II",
            "3": "III",
            "4": "IV",
            "5": "V",
            "6": "VI",
            "7": "VII",
            "8": "VIII",
            "9": "IX",
            "10": "X"
        },
        "persistent-workspaces": {
            "*": 5
        }
    },

    "disk": {
        "format": " {free}",
        "path": "/"
    },

    "network": {
        "format-wifi": " {essid} {signalStrength}%",
        "format-ethernet": " {ipaddr}",
        "format-disconnected": " --",
        "tooltip-format": "{ifname}: {ipaddr}"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "format-charging": " {capacity}%",
        "states": {
            "warning": 30,
            "critical": 15
        }
    },

    "cpu": {
        "format": " {usage}%",
        "interval": 5
    },

    "memory": {
        "format": " {used:0.1f}G / {total:0.1f}G",
        "interval": 5
    },

    "wireplumber": {
        "format": " {volume}%",
        "format-muted": " mudo",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
    },

    "clock": {
        "format": " {:%a %d %b  %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>"
    }
}
